		},
	)
	if len(results) != 0 {
		t.Fatalf("want no results on pre-cancel, got %d", len(results))
	}
	// Every source must report ctx.Err() — no silent drops.
	if len(errs) != len(sources) {
		t.Fatalf("want %d cancel errors, got %d", len(sources), len(errs))
	}
	for i, e := range errs {
